# ── Site URL ──────────────────────────────────────────────
# Local dev can leave this unset. In production, set to the Vercel
# deployment URL (the auto-generated *.vercel.app URL until a custom
# domain is added).
NEXT_PUBLIC_SITE_URL=

# ── Anthropic (required for generative UI) ───────────────
ANTHROPIC_API_KEY=

# ── Add project keys below ────────────────────────────────
# API keys / secrets go here as the prototype grows.
# Register each one in src/lib/env.ts so a missing var fails fast at boot
# instead of silently breaking a request.
